#!/bin/bash
## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## //
##  Chatwoot Enterprise — Habilitar / Desabilitar                          ##
##                                                                         ##
##  Uso (sem baixar o instalador inteiro):                                 ##
##    curl -fsSL .../cmd/chatwoot-enterprise | sudo bash                   ##
##    curl -fsSL .../cmd/chatwoot-enterprise | sudo bash -s -- --disable   ##
## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## //

set -euo pipefail

REPO_RAW="${REPO_RAW:-https://raw.githubusercontent.com/flouds-dncarbonell/installer-flouds/main}"

## Quando invocado via pipe (curl | bash), baixa para arquivo temporário
## e re-executa de lá. Isso evita congelamento com read interativo.
if [ ! -t 0 ]; then
    tmp_script="$(mktemp)"
    curl -fsSL "$REPO_RAW/cmd/chatwoot-enterprise" -o "$tmp_script" || {
        echo "Falha ao baixar o script." >&2; exit 1
    }
    chmod +x "$tmp_script"
    exec bash "$tmp_script" "$@" </dev/tty
fi

## Carrega funções comuns
if ! source <(curl -fsSL "$REPO_RAW/lib/common.sh"); then
    echo "Falha ao carregar lib/common.sh. Verifique a conexão." >&2
    exit 1
fi

exigir_root
exigir_docker

## --- Constantes ---------------------------------------------------------
HUB_FILE="chatwoot_hub.rb"
HUB_HOST_PATH="/root/${HUB_FILE}"
HUB_CONTAINER_PATH="/app/lib/${HUB_FILE}"
HUB_VOLUME_LINE="      - ${HUB_HOST_PATH}:${HUB_CONTAINER_PATH}:ro"
PADROES_SERVICO="rails|sidekiq|worker"

## --- Argumento --disable ------------------------------------------------
MODO="habilitar"
for arg in "$@"; do
    case "$arg" in
        --disable|-d) MODO="desabilitar" ;;
    esac
done

## --- Funções ------------------------------------------------------------

## Lista todas as stacks que contenham serviços com nomes de Chatwoot
encontrar_stack_chatwoot() {
    local stacks_encontradas=""

    while IFS= read -r stack; do
        [ -z "$stack" ] && continue
        if docker stack services "$stack" --format "{{.Name}}" 2>/dev/null | grep -qiE "$PADROES_SERVICO"; then
            stacks_encontradas="${stacks_encontradas}${stack}"$'\n'
        fi
    done < <(docker stack ls --format "{{.Name}}" 2>/dev/null)

    stacks_encontradas=$(echo "$stacks_encontradas" | sed '/^$/d')

    if [ -z "$stacks_encontradas" ]; then
        msg_erro "Nenhuma stack Chatwoot encontrada neste servidor." >&2
        echo "" >&2
        msg_info "O comando procura stacks com serviços chamados rails, sidekiq ou worker." >&2
        msg_info "Instale o Chatwoot antes de usar este comando." >&2
        exit 1
    fi

    local count
    count=$(echo "$stacks_encontradas" | wc -l)

    if [ "$count" -eq 1 ]; then
        echo "$stacks_encontradas"
        return
    fi

    echo "" >&2
    msg_info "Mais de uma stack Chatwoot encontrada:" >&2
    echo "" >&2
    local i=1
    while IFS= read -r stack; do
        [ -z "$stack" ] && continue
        echo -e " $amarelo[$i]$reset $stack" >&2
        i=$((i + 1))
    done <<< "$stacks_encontradas"
    echo "" >&2
    read_rp "Escolha [1-$((count))]: " escolha

    local selecionada
    selecionada=$(echo "$stacks_encontradas" | sed -n "${escolha}p")
    if [ -z "$selecionada" ]; then
        msg_erro "Opção inválida." >&2
        exit 1
    fi
    echo "$selecionada"
}

## Encontra o arquivo YAML da stack no servidor
encontrar_yaml_stack() {
    local stack="$1"

    local candidatos=(
        "/root/${stack}.yaml"
        "/root/${stack}.yml"
        "/root/chatwoot/${stack}.yaml"
        "/root/chatwoot/${stack}.yml"
        "/root/docker/${stack}.yaml"
        "/root/docker/${stack}.yml"
    )

    local yaml_from_label
    yaml_from_label=$(docker service ls --filter "label=com.docker.stack.namespace=${stack}" --format "{{.Name}}" 2>/dev/null | head -1)
    if [ -n "$yaml_from_label" ]; then
        local compose_path
        compose_path=$(docker service inspect "$yaml_from_label" --format '{{index .Spec.Labels "com.docker.compose.project.config_files"}}' 2>/dev/null || true)
        if [ -n "$compose_path" ] && [ -f "$compose_path" ]; then
            echo "$compose_path"
            return
        fi
    fi

    for arquivo in "${candidatos[@]}"; do
        if [ -f "$arquivo" ]; then
            echo "$arquivo"
            return
        fi
    done

    echo "" >&2
    msg_info "Não encontrei o arquivo YAML da stack ${stack}." >&2
    echo -en "$amarelo Caminho do arquivo (ex: /root/chatwoot.yaml): $reset" >&2
    read_r yaml_path

    if [ ! -f "$yaml_path" ]; then
        msg_erro "Arquivo não encontrado: $yaml_path" >&2
        exit 1
    fi
    echo "$yaml_path"
}

## Lista todos os serviços da stack, marca candidatos, e deixa o usuário escolher
selecionar_servicos() {
    local stack="$1"
    local todos
    todos=$(docker stack services "$stack" --format "{{.Name}}" 2>/dev/null)

    if [ -z "$todos" ]; then
        msg_erro "Nenhum serviço encontrado na stack $stack." >&2
        exit 1
    fi

    echo "" >&2
    msg_info "Serviços na stack ${stack}:" >&2
    echo "" >&2
    echo -e "  $amarelo #$reset   $amarelo Serviço$reset                          $amarelo Candidato$reset" >&2
    echo -e "  ─── ─────────────────────────────── ─────────" >&2

    local i=1
    local candidatos=""
    while IFS= read -r svc; do
        [ -z "$svc" ] && continue
        local e_candidato=""
        if echo "$svc" | grep -qiE "$PADROES_SERVICO"; then
            e_candidato="$verde✔$reset"
            candidatos="${candidatos}${i} "
        else
            e_candidato="$bege—$reset"
        fi
        printf "  $amarelo[%2d]$reset %-35s %b\n" "$i" "$svc" "$e_candidato" >&2
        i=$((i + 1))
    done <<< "$todos"

    echo "" >&2
    echo -e "  $bege Candidatos = serviços com nome rails, sidekiq ou worker$reset" >&2
    echo "" >&2

    local total=$((i - 1))
    local sugestao=""
    [ -n "$candidatos" ] && sugestao=$(echo "$candidatos" | tr -s ' ' ',' | sed 's/^,//;s/,$//')

    echo -en "$amarelo Selecione os serviços (ex: 1,3,5) [Enter=$sugestao]: $reset" >&2
    read_r escolha

    [ -z "$escolha" ] && escolha="$sugestao"

    local selecionados=""
    IFS=',' read -ra indices <<< "$escolha"
    for idx in "${indices[@]}"; do
        idx=$(echo "$idx" | tr -d ' ')
        if ! echo "$idx" | grep -qE '^[0-9]+$' || [ "$idx" -lt 1 ] || [ "$idx" -gt "$total" ]; then
            msg_erro "Índice inválido: $idx" >&2
            exit 1
        fi
        local nome
        nome=$(echo "$todos" | sed -n "${idx}p")
        selecionados="${selecionados}${nome}"$'\n'
    done

    echo "$selecionados" | sed '/^$/d'
}

## Verifica se o volume já está no YAML
volume_ja_no_yaml() {
    local yaml_path="$1"
    grep -q "${HUB_HOST_PATH}" "$yaml_path" 2>/dev/null
}

## Injeta o volume no YAML nos serviços selecionados
injetar_no_yaml() {
    local yaml_path="$1"
    local backup="${yaml_path}.bak.$(date +%Y%m%d%H%M%S)"

    cp "$yaml_path" "$backup"
    msg_ok "Backup salvo em ${backup}"

    local tmp
    tmp=$(mktemp)

    awk -v vol_line="$HUB_VOLUME_LINE" -v hub_path="$HUB_HOST_PATH" '
    BEGIN { in_volumes = 0; injected = 0 }

    /^[[:space:]]*volumes:/ {
        in_volumes = 1
        print
        next
    }

    in_volumes && /^[[:space:]]*- / {
        if ($0 ~ hub_path) {
            injected = 1
        }
        print
        next
    }

    in_volumes && !/^[[:space:]]*- / && !/^[[:space:]]*$/ {
        if (!injected) {
            print vol_line
            injected = 1
        }
        in_volumes = 0
        print
        next
    }

    in_volumes && /^[[:space:]]*$/ {
        if (!injected) {
            print vol_line
            injected = 1
        }
        in_volumes = 0
        print
        next
    }

    /^[[:space:]]*[a-z]/{ in_volumes = 0; injected = 0 }

    { print }
    ' "$yaml_path" > "$tmp"

    if ! diff -q "$yaml_path" "$tmp" >/dev/null 2>&1; then
        mv "$tmp" "$yaml_path"
        msg_ok "Volume injetado no YAML: ${HUB_HOST_PATH}:${HUB_CONTAINER_PATH}:ro"
    else
        rm "$tmp"
        msg_ok "Volume já presente no YAML."
    fi
}

## Remove o volume do YAML
remover_do_yaml() {
    local yaml_path="$1"
    local backup="${yaml_path}.bak.$(date +%Y%m%d%H%M%S)"

    cp "$yaml_path" "$backup"
    msg_ok "Backup salvo em ${backup}"

    local tmp
    tmp=$(mktemp)

    grep -v "${HUB_HOST_PATH}" "$yaml_path" > "$tmp"

    if ! diff -q "$yaml_path" "$tmp" >/dev/null 2>&1; then
        mv "$tmp" "$yaml_path"
        msg_ok "Volume removido do YAML."
    else
        rm "$tmp"
        msg_ok "Volume não encontrado no YAML."
    fi
}

## Re-deploy da stack
redeploy_stack() {
    local stack="$1"
    local yaml_path="$2"

    msg_info "Re-deployando stack ${stack}..."
    docker stack deploy --detach=true --resolve-image always -c "$yaml_path" "$stack" >/dev/null 2>&1

    if [ $? -eq 0 ]; then
        msg_ok "Stack ${stack} re-deployada com sucesso."
    else
        msg_erro "Falha ao re-deployar a stack."
        msg_info "O backup do YAML anterior foi mantido. Restaure manualmente se necessário."
        exit 1
    fi
}

## Baixa o chatwoot_hub.rb do repositório
baixar_hub() {
    msg_info "Baixando ${HUB_FILE}..."
    curl -fsSL "$REPO_RAW/${HUB_FILE}" -o "$HUB_HOST_PATH"
    msg_ok "${HUB_FILE} salvo em ${HUB_HOST_PATH}"
}

## Remove o chatwoot_hub.rb do host
remover_hub() {
    if [ -f "$HUB_HOST_PATH" ]; then
        rm "$HUB_HOST_PATH"
        msg_ok "${HUB_HOST_PATH} removido."
    else
        msg_ok "${HUB_HOST_PATH} não encontrado no host."
    fi
}

## --- Principal ----------------------------------------------------------

clear
echo ""
echo -e "$amarelo====================================================================================================$reset"
echo -e "$amarelo=                                                                                                  =$reset"
echo -e "$amarelo=                  $branco Chatwoot Enterprise — $MODO$amarelo                                               =$reset"
echo -e "$amarelo=                                                                                                  =$reset"
echo -e "$amarelo====================================================================================================$reset"
echo ""

if [ "$MODO" = "habilitar" ]; then
    echo -e "$branco Este comando vai:$reset"
    echo -e "$branco   1. Baixar o arquivo chatwoot_hub.rb para /root/$reset"
    echo -e "$branco   2. Encontrar a stack Chatwoot no Docker Swarm$reset"
    echo -e "$branco   3. Injetar o volume no YAML da stack$reset"
    echo -e "$branco   4. Re-deployar a stack$reset"
else
    echo -e "$branco Este comando vai:$reset"
    echo -e "$branco   1. Encontrar a stack Chatwoot no Docker Swarm$reset"
    echo -e "$branco   2. Remover o volume do YAML da stack$reset"
    echo -e "$branco   3. Re-deployar a stack$reset"
    echo -e "$branco   4. Remover o arquivo chatwoot_hub.rb do host$reset"
fi
echo ""
read_rp "Deseja continuar? (Y/N): " confirmar
if [ "$confirmar" != "Y" ] && [ "$confirmar" != "y" ]; then
    echo ""
    msg_info "Operação cancelada."
    exit 0
fi
echo ""

## Passo 1: stack
STACK_CHATWOOT=$(encontrar_stack_chatwoot)
msg_ok "Stack encontrada: $STACK_CHATWOOT"
echo ""

if [ "$MODO" = "habilitar" ]; then

    ## Passo 2: baixar hub
    baixar_hub
    echo ""

    ## Passo 3: selecionar serviços
    SERVICOS_ALVO=$(selecionar_servicos "$STACK_CHATWOOT")

    echo ""
    msg_info "Serviços selecionados:"
    echo "$SERVICOS_ALVO" | while read -r svc; do
        echo -e "  $verde•$reset $svc"
    done
    echo ""

    ## Passo 4: YAML e injetar
    YAML_PATH=$(encontrar_yaml_stack "$STACK_CHATWOOT")
    msg_ok "YAML encontrado: $YAML_PATH"

    if volume_ja_no_yaml "$YAML_PATH"; then
        msg_ok "Volume já está no YAML. Pulando injeção."
    else
        injetar_no_yaml "$YAML_PATH"
    fi
    echo ""

    ## Passo 5: re-deploy
    redeploy_stack "$STACK_CHATWOOT" "$YAML_PATH"
    echo ""

    ## Resultado
    echo -e "$verde====================================================================================================$reset"
    echo -e "$verde=                                                                                                  =$reset"
    echo -e "$verde=  $branco Chatwoot Enterprise habilitado!$verde                                                         =$reset"
    echo -e "$verde=                                                                                                  =$reset"
    echo -e "$verde====================================================================================================$reset"
    echo ""
    echo -e "$amarelo Arquivo:$branco ${HUB_HOST_PATH}$reset"
    echo -e "$amarelo Montado em:$branco ${HUB_CONTAINER_PATH}$reset"
    echo -e "$amarelo YAML:$branco ${YAML_PATH}$reset"
    echo ""
    echo -e "$amarelo Serviços afetados:$reset"
    echo "$SERVICOS_ALVO" | while read -r svc; do
        echo -e "  $verde•$reset $svc"
    done
    echo ""
    echo -e "$bege Para desabilitar:$reset"
    echo -e "$bege   curl -fsSL .../cmd/chatwoot-enterprise | sudo bash -s -- --disable$reset"
    echo ""

else

    ## MODO DESABILITAR

    ## Passo 2: YAML e remover
    YAML_PATH=$(encontrar_yaml_stack "$STACK_CHATWOOT")
    msg_ok "YAML encontrado: $YAML_PATH"

    if volume_ja_no_yaml "$YAML_PATH"; then
        remover_do_yaml "$YAML_PATH"
    else
        msg_ok "Volume não está no YAML. Nada a remover."
    fi
    echo ""

    ## Passo 3: re-deploy
    redeploy_stack "$STACK_CHATWOOT" "$YAML_PATH"
    echo ""

    ## Passo 4: remover arquivo do host
    remover_hub
    echo ""

    ## Resultado
    echo -e "$verde====================================================================================================$reset"
    echo -e "$verde=                                                                                                  =$reset"
    echo -e "$verde=  $branco Chatwoot Enterprise desabilitado!$verde                                                       =$reset"
    echo -e "$verde=                                                                                                  =$reset"
    echo -e "$verde====================================================================================================$reset"
    echo ""
    echo -e "$amarelo Volume removido do YAML:$branco ${YAML_PATH}$reset"
    echo -e "$amarelo Arquivo removido:$branco ${HUB_HOST_PATH}$reset"
    echo ""
    echo -e "$bege Para habilitar novamente:$reset"
    echo -e "$bege   curl -fsSL .../cmd/chatwoot-enterprise | sudo bash$reset"
    echo ""

fi
