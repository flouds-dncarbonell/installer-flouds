#!/bin/bash
## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## //
##  Habilitar Chatwoot Enterprise                                          ##
##                                                                         ##
##  Encontra a stack Chatwoot no Docker Swarm, injeta o volume             ##
##  chatwoot_hub.rb no YAML da stack e re-deploya. Funciona com Portainer ##
##  e cobre todos os serviĂ§os (rails, sidekiq, worker).                    ##
##                                                                         ##
##  Uso (sem baixar o instalador inteiro):                                 ##
##    curl -fsSL https://raw.githubusercontent.com/flouds-dncarbonell/installer-flouds/main/cmd/habilitar-chatwoot-enterprise | sudo bash
## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## //

set -euo pipefail

REPO_RAW="${REPO_RAW:-https://raw.githubusercontent.com/flouds-dncarbonell/installer-flouds/main}"

## Carrega funĂ§Ăµes comuns
if ! source <(curl -fsSL "$REPO_RAW/lib/common.sh"); then
    echo "Falha ao carregar lib/common.sh. Verifique a conexĂŁo." >&2
    exit 1
fi

exigir_root
exigir_docker

## --- Constantes ---------------------------------------------------------
HUB_FILE="chatwoot_hub.rb"
HUB_HOST_PATH="/root/${HUB_FILE}"
HUB_CONTAINER_PATH="/app/lib/${HUB_FILE}"
HUB_VOLUME_LINE="      - ${HUB_HOST_PATH}:${HUB_CONTAINER_PATH}:ro"

## PadrĂµes de nome de serviĂ§o do Chatwoot no Swarm
PADROES_SERVICO="rails|sidekiq|worker"

## --- FunĂ§Ăµes ------------------------------------------------------------

## Lista todas as stacks que contenham serviĂ§os com nomes de Chatwoot
encontrar_stack_chatwoot() {
    local stacks_encontradas=""

    while IFS= read -r stack; do
        [ -z "$stack" ] && continue
        if docker stack services "$stack" --format "{{.Name}}" 2>/dev/null | grep -qiE "$PADROES_SERVICO"; then
            stacks_encontradas="${stacks_encontradas}${stack}"$'\n'
        fi
    done < <(docker stack ls --format "{{.Name}}" 2>/dev/null)

    ## Remove linhas vazias
    stacks_encontradas=$(echo "$stacks_encontradas" | sed '/^$/d')

    if [ -z "$stacks_encontradas" ]; then
        msg_erro "Nenhuma stack Chatwoot encontrada neste servidor."
        echo ""
        msg_info "O comando procura stacks com serviĂ§os chamados rails, sidekiq ou worker."
        msg_info "Instale o Chatwoot antes de habilitar o Enterprise."
        exit 1
    fi

    local count
    count=$(echo "$stacks_encontradas" | wc -l)

    if [ "$count" -eq 1 ]; then
        echo "$stacks_encontradas"
        return
    fi

    echo ""
    msg_info "Mais de uma stack Chatwoot encontrada:"
    echo ""
    local i=1
    while IFS= read -r stack; do
        [ -z "$stack" ] && continue
        echo -e " $amarelo[$i]$reset $stack"
        i=$((i + 1))
    done <<< "$stacks_encontradas"
    echo ""
    read -rp "Escolha [1-$((count))]: " escolha

    local selecionada
    selecionada=$(echo "$stacks_encontradas" | sed -n "${escolha}p")
    if [ -z "$selecionada" ]; then
        msg_erro "OpĂ§ĂŁo invĂˇlida."
        exit 1
    fi
    echo "$selecionada"
}

## Encontra o arquivo YAML da stack no servidor
encontrar_yaml_stack() {
    local stack="$1"

    ## Procura em locais comuns
    local candidatos=(
        "/root/${stack}.yaml"
        "/root/${stack}.yml"
        "/root/chatwoot/${stack}.yaml"
        "/root/chatwoot/${stack}.yml"
        "/root/docker/${stack}.yaml"
        "/root/docker/${stack}.yml"
    )

    ## TambĂ©m procura pelo YAML que gerou a stack (docker stack deploy -c <file>)
    ## checando labels do serviĂ§o
    local yaml_from_label
    yaml_from_label=$(docker service ls --filter "label=com.docker.stack.namespace=${stack}" --format "{{.Name}}" 2>/dev/null | head -1)
    if [ -n "$yaml_from_label" ]; then
        local compose_path
        compose_path=$(docker service inspect "$yaml_from_label" --format '{{index .Spec.Labels "com.docker.compose.project.config_files"}}' 2>/dev/null || true)
        if [ -n "$compose_path" ] && [ -f "$compose_path" ]; then
            echo "$compose_path"
            return
        fi
    fi

    for arquivo in "${candidatos[@]}"; do
        if [ -f "$arquivo" ]; then
            echo "$arquivo"
            return
        fi
    done

    ## NĂŁo encontrou â€” pergunta ao usuĂˇrio
    echo ""
    msg_info "NĂŁo encontrei o arquivo YAML da stack ${stack}."
    echo -en "$amarelo Caminho do arquivo (ex: /root/chatwoot.yaml): $reset"
    read -r yaml_path

    if [ ! -f "$yaml_path" ]; then
        msg_erro "Arquivo nĂŁo encontrado: $yaml_path"
        exit 1
    fi
    echo "$yaml_path"
}

## Lista todos os serviĂ§os da stack, marca candidatos, e deixa o usuĂˇrio escolher
selecionar_servicos() {
    local stack="$1"
    local todos
    todos=$(docker stack services "$stack" --format "{{.Name}}" 2>/dev/null)

    if [ -z "$todos" ]; then
        msg_erro "Nenhum serviĂ§o encontrado na stack $stack."
        exit 1
    fi

    echo ""
    msg_info "ServiĂ§os na stack ${stack}:"
    echo ""
    echo -e "  $amarelo #$reset   $amarelo ServiĂ§o$reset                          $amarelo Candidato$reset"
    echo -e "  â”€â”€â”€ â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ â”€â”€â”€â”€â”€â”€â”€â”€â”€"

    local i=1
    local candidatos=""
    while IFS= read -r svc; do
        [ -z "$svc" ] && continue
        local e_candidato=""
        if echo "$svc" | grep -qiE "$PADROES_SERVICO"; then
            e_candidato="$verdeâś”$reset"
            candidatos="${candidatos}${i} "
        else
            e_candidato="$begeâ€”$reset"
        fi
        printf "  $amarelo[%2d]$reset %-35s %b\n" "$i" "$svc" "$e_candidato"
        i=$((i + 1))
    done <<< "$todos"

    echo ""
    echo -e "  $bege Candidatos = serviĂ§os com nome rails, sidekiq ou worker$reset"
    echo ""

    local total=$((i - 1))
    local sugestao=""
    [ -n "$candidatos" ] && sugestao=$(echo "$candidatos" | tr -s ' ' ',' | sed 's/^,//;s/,$//')

    echo -en "$amarelo Selecione os serviĂ§os (ex: 1,3,5) [Enter=$sugestao]: $reset"
    read -r escolha

    [ -z "$escolha" ] && escolha="$sugestao"

    ## Valida e resolve nomes
    local selecionados=""
    IFS=',' read -ra indices <<< "$escolha"
    for idx in "${indices[@]}"; do
        idx=$(echo "$idx" | tr -d ' ')
        if ! echo "$idx" | grep -qE '^[0-9]+$' || [ "$idx" -lt 1 ] || [ "$idx" -gt "$total" ]; then
            msg_erro "ĂŤndice invĂˇlido: $idx"
            exit 1
        fi
        local nome
        nome=$(echo "$todos" | sed -n "${idx}p")
        selecionados="${selecionados}${nome}"$'\n'
    done

    echo "$selecionados" | sed '/^$/d'
}

## Verifica se o volume jĂˇ estĂˇ no YAML
volume_ja_no_yaml() {
    local yaml_path="$1"
    grep -q "${HUB_HOST_PATH}" "$yaml_path" 2>/dev/null
}

## Injeta o volume no YAML em todos os serviĂ§os relevantes
injetar_no_yaml() {
    local yaml_path="$1"
    local backup="${yaml_path}.bak.$(date +%Y%m%d%H%M%S)"

    ## Backup
    cp "$yaml_path" "$backup"
    msg_ok "Backup salvo em ${backup}"

    ## Para cada serviĂ§o que tem volumes:, adiciona a linha apĂłs a Ăşltima linha de volume
    ## Usa awk para injetar de forma precisa
    local tmp
    tmp=$(mktemp)

    awk -v vol_line="$HUB_VOLUME_LINE" -v hub_path="$HUB_HOST_PATH" '
    BEGIN { in_volumes = 0; injected = 0 }

    ## Detecta bloco volumes: dentro de um serviĂ§o
    /^[[:space:]]*volumes:/ {
        in_volumes = 1
        print
        next
    }

    ## Se estamos num bloco volumes e a linha Ă© um volume existente (indentado)
    in_volumes && /^[[:space:]]*- / {
        ## Verifica se este volume jĂˇ Ă© o chatwoot_hub
        if ($0 ~ hub_path) {
            injected = 1
        }
        print
        next
    }

    ## Saiu do bloco volumes â€” injeta antes de sair se ainda nĂŁo injetou
    in_volumes && !/^[[:space:]]*- / && !/^[[:space:]]*$/ {
        if (!injected) {
            print vol_line
            injected = 1
        }
        in_volumes = 0
        print
        next
    }

    ## Linha vazia saindo de volumes
    in_volumes && /^[[:space:]]*$/ {
        if (!injected) {
            print vol_line
            injected = 1
        }
        in_volumes = 0
        print
        next
    }

    ## Reset ao encontrar novo serviĂ§o
    /^[[:space:]]*[a-z]/{ in_volumes = 0; injected = 0 }

    { print }
    ' "$yaml_path" > "$tmp"

    ## Verifica se algo mudou
    if ! diff -q "$yaml_path" "$tmp" >/dev/null 2>&1; then
        mv "$tmp" "$yaml_path"
        msg_ok "Volume injetado no YAML: ${HUB_HOST_PATH}:${HUB_CONTAINER_PATH}:ro"
    else
        rm "$tmp"
        msg_ok "Volume jĂˇ presente no YAML."
    fi
}

## Faz re-deploy da stack com o YAML atualizado
redeploy_stack() {
    local stack="$1"
    local yaml_path="$2"

    msg_info "Re-deployando stack ${stack}..."
    docker stack deploy --detach=true --resolve-image always -c "$yaml_path" "$stack" >/dev/null 2>&1

    if [ $? -eq 0 ]; then
        msg_ok "Stack ${stack} re-deployada com sucesso."
    else
        msg_erro "Falha ao re-deployar a stack."
        msg_info "O backup do YAML anterior foi mantido. Restaure manualmente se necessĂˇrio."
        exit 1
    fi
}

## Baixa o chatwoot_hub.rb do repositĂłrio
baixar_hub() {
    msg_info "Baixando ${HUB_FILE}..."
    curl -fsSL "$REPO_RAW/${HUB_FILE}" -o "$HUB_HOST_PATH"
    msg_ok "${HUB_FILE} salvo em ${HUB_HOST_PATH}"
}

## --- Principal ----------------------------------------------------------

clear
echo ""
echo -e "$amarelo====================================================================================================$reset"
echo -e "$amarelo=                                                                                                  =$reset"
echo -e "$amarelo=                  $branco Habilitar Chatwoot Enterprise$amarelo                                               =$reset"
echo -e "$amarelo=                                                                                                  =$reset"
echo -e "$amarelo====================================================================================================$reset"
echo ""
echo -e "$branco Este comando vai:$reset"
echo -e "$branco   1. Baixar o arquivo chatwoot_hub.rb para /root/$reset"
echo -e "$branco   2. Encontrar a stack Chatwoot no Docker Swarm$reset"
echo -e "$branco   3. Injetar o volume no YAML da stack (rails + sidekiq + worker)$reset"
echo -e "$branco   4. Re-deployar a stack$reset"
echo ""
read -rp "Deseja continuar? (Y/N): " confirmar
if [ "$confirmar" != "Y" ] && [ "$confirmar" != "y" ]; then
    echo ""
    msg_info "OperaĂ§ĂŁo cancelada."
    exit 0
fi
echo ""

## Passo 1: baixar o arquivo
baixar_hub
echo ""

## Passo 2: encontrar a stack
STACK_CHATWOOT=$(encontrar_stack_chatwoot)
msg_ok "Stack encontrada: $STACK_CHATWOOT"
echo ""

## Passo 3: selecionar serviĂ§os
SERVICOS_ALVO=$(selecionar_servicos "$STACK_CHATWOOT")

echo ""
msg_info "ServiĂ§os selecionados:"
echo "$SERVICOS_ALVO" | while read -r svc; do
    echo -e "  $verdeâ€˘$reset $svc"
done
echo ""

## Passo 4: encontrar o YAML e injetar
YAML_PATH=$(encontrar_yaml_stack "$STACK_CHATWOOT")
msg_ok "YAML encontrado: $YAML_PATH"

if volume_ja_no_yaml "$YAML_PATH"; then
    msg_ok "Volume jĂˇ estĂˇ no YAML. Pulando injeĂ§ĂŁo."
else
    injetar_no_yaml "$YAML_PATH"
fi
echo ""

## Passo 5: re-deploy
redeploy_stack "$STACK_CHATWOOT" "$YAML_PATH"
echo ""

## Resultado
echo -e "$verde====================================================================================================$reset"
echo -e "$verde=                                                                                                  =$reset"
echo -e "$verde=  $branco Chatwoot Enterprise habilitado com sucesso!$verde                                              =$reset"
echo -e "$verde=                                                                                                  =$reset"
echo -e "$verde====================================================================================================$reset"
echo ""
echo -e "$amarelo Arquivo:$branco ${HUB_HOST_PATH}$reset"
echo -e "$amarelo Montado em:$branco ${HUB_CONTAINER_PATH}$reset"
echo -e "$amarelo YAML:$branco ${YAML_PATH}$reset"
echo ""
echo -e "$amarelo ServiĂ§os afetados:$reset"
echo "$SERVICOS_ALVO" | while read -r svc; do
    echo -e "  $verdeâ€˘$reset $svc"
done
echo ""
echo -e "$bege â„ą O YAML original foi backupeado no mesmo diretĂłrio.$reset"
echo -e "$bege â„ą Se usar Portainer, a stack aparecerĂˇ atualizada automaticamente.$reset"
echo ""
