#!/bin/bash

## Cores
amarelo="\e[33m"
verde="\e[32m"
branco="\e[97m"
vermelho="\e[91m"
reset="\e[0m"
SETUP_URL="https://raw.githubusercontent.com/flouds-dncarbonell/installer-flouds/main/Setup"
INSTALLER_URL="https://raw.githubusercontent.com/flouds-dncarbonell/installer-flouds/main/SetupFlouds"

clear
echo ""
echo -e "$amarelo====================================================================================================$reset"
echo -e "$amarelo=                                                                                                  =$reset"
echo -e "$amarelo=                    $branco‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó      ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó$amarelo                    =$reset"
echo -e "$amarelo=                    $branco‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ$amarelo                    =$reset"
echo -e "$amarelo=                    $branco‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó$amarelo                    =$reset"
echo -e "$amarelo=                    $branco‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚ēö‚ēź‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēĎ$amarelo                    =$reset"
echo -e "$amarelo=                    $branco‚Ėą‚Ėą‚ēĎ     ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ$amarelo                    =$reset"
echo -e "$amarelo=                    $branco‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ$amarelo                    =$reset"
echo -e "$amarelo=                                                                                                  =$reset"
echo -e "$amarelo====================================================================================================$reset"
echo ""
echo -e "$branco Aguarde enquanto preparamos o ambiente...$reset"
echo ""
sleep 1

## Verifica root
if [ "$(id -u)" -ne 0 ]; then
    if command -v sudo &>/dev/null; then
        echo -e "$amarelo Reexecutando com sudo...$reset"
        tmp_script="$(mktemp)"
        curl -fsSL "$SETUP_URL" -o "$tmp_script" || {
            echo -e "$vermelho Erro ao baixar o instalador para executar com sudo.$reset"
            exit 1
        }
        exec sudo bash "$tmp_script" "$@"
    fi
    echo -e "$vermelho Este script precisa ser executado como root.$reset"
    exit 1
fi

## Garante estar em /root
cd /root || exit 1

## Atualiza o sistema
echo -e "$amarelo[1/8]$reset Atualizando o sistema..."
apt update -y > /dev/null 2>&1 && echo -e "$verde  ‚úĒ OK$reset" || echo -e "$vermelho  ‚úĖ Falhou$reset"

echo -e "$amarelo[2/8]$reset Fazendo upgrade..."
apt upgrade -y > /dev/null 2>&1 && echo -e "$verde  ‚úĒ OK$reset" || echo -e "$vermelho  ‚úĖ Falhou$reset"

echo -e "$amarelo[3/8]$reset Instalando sudo..."
apt install sudo -y > /dev/null 2>&1 && echo -e "$verde  ‚úĒ OK$reset" || echo -e "$vermelho  ‚úĖ Falhou$reset"

echo -e "$amarelo[4/8]$reset Instalando apt-utils..."
apt-get install -y apt-utils > /dev/null 2>&1 && echo -e "$verde  ‚úĒ OK$reset" || echo -e "$vermelho  ‚úĖ Falhou$reset"

echo -e "$amarelo[5/8]$reset Instalando jq..."
apt-get install -y jq > /dev/null 2>&1 && echo -e "$verde  ‚úĒ OK$reset" || echo -e "$vermelho  ‚úĖ Falhou$reset"

echo -e "$amarelo[6/8]$reset Instalando git e curl..."
apt install -y git curl > /dev/null 2>&1 && echo -e "$verde  ‚úĒ OK$reset" || echo -e "$vermelho  ‚úĖ Falhou$reset"

echo -e "$amarelo[7/8]$reset Instalando apache2-utils..."
apt install -y apache2-utils > /dev/null 2>&1 && echo -e "$verde  ‚úĒ OK$reset" || echo -e "$vermelho  ‚úĖ Falhou$reset"

## Instala Docker se n√£o existir
echo -e "$amarelo[8/8]$reset Verificando Docker..."
if ! command -v docker &> /dev/null; then
    echo -e "       Instalando Docker..."
    curl -fsSL https://get.docker.com | sh > /dev/null 2>&1
    echo -e "$verde  ‚úĒ Docker instalado$reset"
else
    echo -e "$verde  ‚úĒ Docker j√° instalado$reset"
fi

echo ""

## Verifica/inicia Swarm
SWARM_STATUS=$(docker info --format '{{.Swarm.LocalNodeState}}' 2>/dev/null)
if [ "$SWARM_STATUS" != "active" ]; then
    echo -e "$amarelo Iniciando Docker Swarm...$reset"
    docker swarm init > /dev/null 2>&1 && echo -e "$verde  ‚úĒ Swarm iniciado$reset" || echo -e "$vermelho  ‚úĖ Falha ao iniciar Swarm$reset"
else
    echo -e "$verde  ‚úĒ Docker Swarm j√° est√° ativo$reset"
fi

echo ""
echo -e "$verde Ambiente pronto! Iniciando o instalador Flouds...$reset"
echo ""
sleep 2

## Remove vers√£o anterior do instalador se existir
[ -e "SetupFlouds" ] && rm SetupFlouds

## Baixa e executa o instalador principal
curl -fsSL "$INSTALLER_URL" -o SetupFlouds
if [ $? -eq 0 ]; then
    chmod +x SetupFlouds
    ./SetupFlouds
else
    echo -e "$vermelho Erro ao baixar o instalador. Verifique sua conex√£o.$reset"
    exit 1
fi
