    docker volume create portainer_data > /dev/null 2>&1
    echo -e "$verde  ✔ Volumes criados$reset"
    echo ""

    echo -e "$amarelo• Deployando stack...$reset"
    docker stack deploy -c traefik_portainer.yaml traefik --with-registry-auth > /dev/null 2>&1
    docker stack deploy -c traefik_portainer.yaml portainer --with-registry-auth > /dev/null 2>&1

    ## Deploy direto (sem API do Portainer pois ainda não está pronto)
    docker stack deploy -c traefik_portainer.yaml traefik_portainer --with-registry-auth
    echo ""

    sleep 5

    instalado_msg
    guarde_os_dados_msg

    echo -e "$verde [ TRAEFIK & PORTAINER ]$reset"
