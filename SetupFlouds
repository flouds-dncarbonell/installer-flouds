## Deploy da stack via API do Portainer
deploy() {
    local STACK_NAME="$1"

    echo ""
    echo -e "$amarelo Iniciando deploy via Portainer API...$reset"
    echo ""

    ## Pega credenciais salvas
    sed -i 's|Dominio do portainer: https://||' "$dados_portainer_file" 2>/dev/null

    PORTAINER_URL=$(grep "Dominio do portainer:" "$dados_portainer_file" | awk -F': ' '{print $2}')
    USUARIO=$(grep "Usuario:" "$dados_portainer_file" | awk -F': ' '{print $2}')
    SENHA=$(grep "Senha:" "$dados_portainer_file" | awk -F': ' '{print $2}')

    echo -e "1/6 - Credenciais carregadas"

    ## Obt√©m token JWT
    local tentativa=0
    TOKEN=""
    while [ -z "$TOKEN" ] || [ "$TOKEN" = "null" ]; do
        tentativa=$((tentativa + 1))
        TOKEN=$(curl -k -s -X POST \
            -H "Content-Type: application/json" \
            -d "{\"username\":\"$USUARIO\",\"password\":\"$SENHA\"}" \
            "https://$PORTAINER_URL/api/auth" | jq -r .jwt 2>/dev/null)

        if [ "$tentativa" -ge 5 ]; then
            echo -e "2/6 - $vermelho[ ERRO ] Falha ao obter token do Portainer ap√≥s 5 tentativas$reset"
            echo -e "      Verifique as credenciais e tente novamente."
            sleep 3
            criar_arquivo_portainer
            return 1
        fi
        [ -z "$TOKEN" ] || [ "$TOKEN" = "null" ] && sleep 3
    done
    echo -e "2/6 - Token obtido"

    ## Salva token
    sed -i "s|Token: .*|Token: $TOKEN|" "$dados_portainer_file"

    ## Pega Endpoint ID
    ENDPOINT_ID=$(curl -k -s -X GET \
        -H "Authorization: Bearer $TOKEN" \
        "https://$PORTAINER_URL/api/endpoints" | jq -r '.[] | select(.Name == "primary") | .Id' 2>/dev/null)
    echo -e "3/6 - Endpoint ID: $bege$ENDPOINT_ID$reset"

    ## Pega Swarm ID
    SWARM_ID=$(curl -k -s -X GET \
        -H "Authorization: Bearer $TOKEN" \
        "https://$PORTAINER_URL/api/endpoints/$ENDPOINT_ID/docker/swarm" | jq -r .ID 2>/dev/null)
    echo -e "4/6 - Swarm ID obtido"

    ## Verifica Swarm
    if [ "$(docker info --format '{{.Swarm.LocalNodeState}}' 2>/dev/null)" != "active" ]; then
        echo -e "5/6 - $vermelho[ ERRO ] Docker Swarm n√£o est√° ativo$reset"
        return 1
    fi
    echo -e "5/6 - Docker Swarm ativo"

    ## Faz o deploy
    local erro_output response_output http_code response_body
    erro_output=$(mktemp)
    response_output=$(mktemp)

    http_code=$(curl -s -o "$response_output" -w "%{http_code}" -k -X POST \
        -H "Authorization: Bearer $TOKEN" \
        -F "Name=$STACK_NAME" \
        -F "file=@$(pwd)/${STACK_NAME}.yaml" \
        -F "SwarmID=$SWARM_ID" \
        -F "endpointId=$ENDPOINT_ID" \
        "https://$PORTAINER_URL/api/stacks/create/swarm/file" 2>"$erro_output")

    response_body=$(cat "$response_output")

    if [ "$http_code" -eq 200 ] && echo "$response_body" | grep -q '"Id"'; then
        echo -e "6/6 - $verde[ OK ] Stack $bege$STACK_NAME$verde deployada com sucesso!$reset"
    else
        echo -e "6/6 - $vermelho[ ERRO ] Falha no deploy (HTTP $http_code)$reset"
        echo -e "      $(echo "$response_body" | jq -r '.message // .details // .' 2>/dev/null)"
    fi

    rm -f "$erro_output" "$response_output"
    echo ""
}

