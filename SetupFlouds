configurar_firewall_http_https() {
    if command -v ufw >/dev/null 2>&1 && ufw status 2>/dev/null | grep -qi "Status: active"; then
        echo -e "$amarelo‚ÄĘ Liberando portas 80/443 no UFW...$reset"
        ufw allow 80/tcp >/dev/null 2>&1
        ufw allow 443/tcp >/dev/null 2>&1
        echo -e "$verde  ‚úĒ Firewall local OK$reset"
        echo ""
    fi
}

validar_portas_http_https() {
    local portas_ocupadas=""

    if command -v ss >/dev/null 2>&1; then
        ss -ltnH 2>/dev/null | awk '{print $4}' | grep -Eq '(^|:)80$' && portas_ocupadas="$portas_ocupadas 80"
        ss -ltnH 2>/dev/null | awk '{print $4}' | grep -Eq '(^|:)443$' && portas_ocupadas="$portas_ocupadas 443"
    fi

    if [ -n "$portas_ocupadas" ] && ! docker service ls --format "{{.Name}}" 2>/dev/null | grep -q "^traefik_traefik$"; then
        clear
        erro_msg
        echo ""
        echo -e " As portas$amarelo$portas_ocupadas$reset j√° parecem estar em uso."
        echo -e " O Traefik precisa publicar as portas $amarelo80$reset e $amarelo443$reset para emitir SSL."
        echo ""
        echo -e " Pare o servi√ßo que usa essas portas e tente novamente."
        echo ""
        sleep 8
        return 1
    fi

    return 0
}

validar_dominio_para_ssl() {
    local dominio
    local ip_vps
    local ips_dominio

    dominio=$(normalizar_dominio "$1")
    ip_vps=$(obter_ip_publico)
    ips_dominio=$(getent ahostsv4 "$dominio" 2>/dev/null | awk '{print $1}' | sort -u | tr '\n' ' ')

    if [ -z "$ip_vps" ]; then
        echo -e "$bege  ‚ö† N√£o foi poss√≠vel detectar o IP p√ļblico da VPS. Continuando.$reset"
        echo ""
        return 0
    fi

    if [ -z "$ips_dominio" ]; then
        clear
        erro_msg
        echo ""
        echo -e " O dom√≠nio $amarelo$dominio$reset n√£o resolveu em DNS p√ļblico."
        echo -e " Crie um registro A apontando para o IP da VPS: $amarelo$ip_vps$reset"
        echo ""
        echo -e " Sem isso, a Let's Encrypt n√£o consegue emitir o certificado SSL."
