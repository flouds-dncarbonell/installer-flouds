## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## //
## INÍCIO
## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## // ## //

## Verifica root
if [ "$(id -u)" -ne 0 ]; then
    echo -e "$vermelho Este script precisa ser executado como root.$reset"
    exit 1
fi

cd /root || exit 1

## Tela de boas-vindas
nome_instalador

echo -e "$amarelo====================================================================================================$reset"
echo -e "$amarelo=                                                                                                  =$reset"
echo -e "$amarelo=  $branco Este instalador foi desenvolvido pela equipe Flouds para facilitar a implantação         $amarelo=$reset"
echo -e "$amarelo=  $branco da plataforma Fzap em servidores VPS com Docker Swarm.                                  $amarelo=$reset"
echo -e "$amarelo=                                                                                                  =$reset"
echo -e "$amarelo====================================================================================================$reset"
echo ""
echo ""
read -rp "Pressione ENTER para continuar..."

## Loop principal
while true; do

    nome_menu
    menu_instalador

    if ! read -rp "Digite o número da opção desejada: " opcao; then
        echo ""
        echo -e "$vermelho Não foi possível ler a opção. Execute o instalador em um terminal interativo.$reset"
        exit 1
    fi

    case $opcao in

        1|traefik|portainer)
            verificar_stack "traefik_portainer" && continue || echo ""
            ferramenta_traefik_e_portainer
            ;;

        2|fzap|FZAP)
            verificar_stack "postgres" && continue || echo ""
            verificar_stack "fzap" && continue || echo ""
            verificar_docker_e_portainer_traefik || continue
            ferramenta_fzap
            ;;

        0|sair|exit)
            nome_finalizado
            echo -e "$branco Até mais!$reset"
            echo ""
            exit 0
            ;;

        *)
            clear
            erro_msg
            echo ""
            echo -e " Opção inválida. Digite 1, 2 ou 0."
            echo ""
            sleep 3
            ;;
    esac

done
