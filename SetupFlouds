ferramenta_fzap() {

    recursos 1 2 && return

    clear

    dados

    nome_fzap
    preencha_as_info

    while true; do

        echo -e "$amarelo Passo 1/2$reset"
        echo -en "$amarelo Digite o domГӯnio da Fzap (ex: fzap.seudominio.com): $reset" && read -r url_fzap
        echo ""

        echo -e "$amarelo Passo 2/2$reset"
