    echo ""
    echo -e "$amarelo LicenГ§a:$branco ${licence_key:-versГЈo free}$reset"
    echo ""
    echo -e "$verde [ BANCO DE DADOS ]$reset"
    echo ""
    echo -e "$amarelo Host (interno):$branco postgres_postgres$reset"
    echo ""
    echo -e "$amarelo Porta:$branco 5432$reset"
    echo ""
    echo -e "$amarelo UsuГЎrio:$branco postgres$reset"
    echo ""
    echo -e "$amarelo Senha:$branco $senha_postgres$reset"
    echo ""
    echo -e "$amarelo Database:$branco fzap$reset"
    echo ""

    requisitar_outra_instalacao
}

