menu_instalador() {
    echo -e "${amarelo}[ 1 ]${reset} - ${branco}Traefik & Portainer${reset}"
    echo -e "${amarelo}[ 2 ]${reset} - ${branco}Fzap${reset}"
    echo ""
    echo -e "${amarelo}[ 0 ]${reset} - ${branco}Sair${reset}"
