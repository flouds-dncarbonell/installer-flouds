        erro_msg
        echo ""
        echo -e " O dom√≠nio $amarelo$dominio$reset n√£o aponta diretamente para esta VPS."
        echo -e " IP da VPS: $amarelo$ip_vps$reset"
        echo -e " IP(s) do dom√≠nio: $amarelo$ips_dominio$reset"
        echo ""
        echo -e " Para SSL autom√°tico, o dom√≠nio precisa chegar nesta VPS pelas portas 80 e 443."
        echo -e " Se voc√™ usa proxy como Cloudflare, pode continuar desde que ele esteja apontando para esta VPS."
