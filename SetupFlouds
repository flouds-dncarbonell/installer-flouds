wait_stack() {
    local stack="$1"
    local tentativa=1
    local max_tentativas="${2:-36}"
    local intervalo="${3:-5}"
    local pendentes

    echo -e "$amarelo‚ÄĘ Aguardando servi√ßos da stack $stack ficarem online...$reset"

    while [ "$tentativa" -le "$max_tentativas" ]; do
        pendentes=$(docker stack services "$stack" --format "{{.Name}} {{.Replicas}}" 2>/dev/null | awk '{
            split($2, replicas, "/")
            if (replicas[1] != replicas[2] || replicas[2] == "0") print $0
        }')

        if [ -z "$pendentes" ] && [ -n "$(docker stack services "$stack" --format "{{.Name}}" 2>/dev/null)" ]; then
            echo -e "$verde  ‚úĒ Stack $stack online$reset"
            echo ""
            return 0
        fi

        sleep "$intervalo"
        tentativa=$((tentativa + 1))
    done

    echo -e "$vermelho  ‚úĖ Stack $stack n√£o ficou online dentro do tempo esperado$reset"
    echo ""
    docker stack services "$stack" 2>/dev/null
    echo ""
    echo -e " Verifique com:"
    echo -e " $amarelo docker service ps ${stack}_NOME_DO_SERVICO --no-trunc$reset"
    echo -e " $amarelo docker service logs ${stack}_NOME_DO_SERVICO --tail 100$reset"
    echo ""
    return 1
}

gerar_traefik_yaml() {
    cat > traefik.yaml << EOF
version: "3.7"

services:

  traefik:
    image: ${traefik_image}
    command:
      - --api.dashboard=true
      - --providers.swarm.endpoint=unix:///var/run/docker.sock
      - --providers.swarm.exposedbydefault=false
      - --providers.swarm.network=${nome_rede_interna}
      - --entrypoints.web.address=:80
      - --entrypoints.web.http.redirections.entrypoint.to=websecure
      - --entrypoints.web.http.redirections.entrypoint.scheme=https
      - --entrypoints.web.http.redirections.entrypoint.permanent=true
      - --entrypoints.websecure.address=:443
      - --entrypoints.web.transport.respondingTimeouts.idleTimeout=3600
      - --certificatesresolvers.letsencryptresolver.acme.httpchallenge=true
      - --certificatesresolvers.letsencryptresolver.acme.httpchallenge.entrypoint=web
      - --certificatesresolvers.letsencryptresolver.acme.email=${email_ssl}
      - --certificatesresolvers.letsencryptresolver.acme.storage=/etc/traefik/letsencrypt/acme.json
      - --log.level=DEBUG
      - --log.format=common
      - --accesslog=true
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
