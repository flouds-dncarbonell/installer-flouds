      mode: replicated
      replicas: 1
      placement:
        constraints:
          - node.role == manager
      resources:
        limits:
          cpus: "1"
          memory: 512M

volumes:
  fzap_dbdata:
    name: fzap_dbdata
    external: true

networks:
  ${nome_rede_interna}:
    external: true
    name: ${nome_rede_interna}
EOF
    echo -e "$verde  вң” YAML postgres gerado$reset"
    echo ""

    deploy "postgres"

    ## -------------------------------------------------------------------------
    ## STACK 2: fzap
    ## -------------------------------------------------------------------------

    echo -e "$amareloвҖў Criando volumes da aplicaГ§ГЈo...$reset"
    docker volume create fzap_files > /dev/null 2>&1
