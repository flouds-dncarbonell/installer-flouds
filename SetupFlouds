        echo -en "$amarelo Chave de licenГ§a Flouds (pressione Enter para pular): $reset" && read -r licence_key
        echo ""

        ## Auto-gera credenciais
        senha_postgres=$(gerar_token 24)
        admin_token=$(gerar_token 32)

        clear
        nome_fzap
        conferindo_as_info

        echo -e "$amarelo DomГӯnio da Fzap:$branco $url_fzap$reset"
        echo ""
        echo -e "$amarelo Rede interna:$branco $nome_rede_interna$reset"
        echo ""
