## Gera string aleat√≥ria segura
gerar_token() {
    local tamanho="${1:-32}"
    tr -dc 'A-Za-z0-9' < /dev/urandom | head -c "$tamanho"
}

## Oculta senha para exibi√ß√£o
esconder_senha() {
    local senha="$1"
    local visivel=4
    local tamanho=${#senha}
    if [ "$tamanho" -le "$visivel" ]; then
        SENHAOCULTA="****"
    else
        SENHAOCULTA="${senha:0:$visivel}$(printf '*%.0s' $(seq 1 $((tamanho - visivel))))"
    fi
}

## Valida senha
validar_senha() {
    local senha="$1"
    local min="${2:-12}"
    if [ ${#senha} -lt "$min" ]; then
        echo -e "$vermelho  Senha muito curta. M√≠nimo $min caracteres.$reset"
        return 1
    fi
    return 0
}

## Verifica se stack j√° existe no Swarm
verificar_stack() {
    local nome_stack="$1"
    if docker stack ls --format "{{.Name}}" 2>/dev/null | grep -q "^${nome_stack}$"; then
        clear
        erro_msg
        echo ""
        echo -e " A stack $amarelo${nome_stack}$reset j√° est√° instalada."
        echo -e " Para reinstalar, remova a stack no Portainer e tente novamente."
        echo ""
        echo -e " Voltando ao menu em 8 segundos..."
        sleep 8
        return 0
    fi
    return 1
}

## Verifica recursos m√≠nimos (vCPU e GB RAM)
recursos() {
    local vcpu_req=$1
    local ram_req=$2

    local vcpu_disp
    local ram_disp

    vcpu_disp=$(nproc 2>/dev/null || echo 1)
    ram_disp=$(free -g 2>/dev/null | awk '/^Mem:/{print $2}')
    ram_disp=${ram_disp:-1}

    if [ "$vcpu_disp" -lt "$vcpu_req" ] || [ "$ram_disp" -lt "$ram_req" ]; then
        clear
        erro_msg
        echo ""
        echo -e " Recursos insuficientes para esta instala√ß√£o."
        echo -e " Necess√°rio: $amarelo${vcpu_req} vCPU$reset e $amarelo${ram_req}GB RAM$reset"
        echo -e " Dispon√≠vel: $amarelo${vcpu_disp} vCPU$reset e $amarelo${ram_disp}GB RAM$reset"
        echo ""
        echo -e " Deseja continuar mesmo assim? (y/n): "
        read -r escolha
        if [ "$escolha" != "y" ] && [ "$escolha" != "Y" ]; then
            return 0
        fi
    fi
    return 1
}

normalizar_dominio() {
    local dominio="$1"
